---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { Card } from '@/components/ui/Card';
import { ExampleSelector } from '@/components/ips/ExampleSelector';
import { BundleUploader } from '@/components/ips/BundleUploader';
import { BundlePreview } from '@/components/ips/BundlePreview';
import { BundleValidator } from '@/components/ips/BundleValidator';

const url = new URL(Astro.request.url);
const patientId = url.searchParams.get('patientId');
---

<Layout title="Upload IPS Bundle">
  <Header slot="header" />
  
  <div class="container-custom py-8">
    <div class="max-w-4xl mx-auto">
      <div class="mb-6">
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Upload IPS Bundle</h1>
        <p class="text-slate-600">
          Select a pre-loaded example or upload your own IPS Bundle JSON file
        </p>
        {patientId && (
          <p class="mt-2 text-sm text-primary-600">
            Bundle will be submitted for Patient ID: <span class="font-mono">{patientId}</span>
          </p>
        )}
      </div>

      <div class="space-y-6">
        <Card title="Option 1: Select Example File">
          <ExampleSelector 
            client:load
            onSelect={(bundle, example) => {
              // Trigger bundle preview update
              window.dispatchEvent(new CustomEvent('bundleSelected', { 
                detail: { bundle, example, patientId } 
              }));
            }}
          />
        </Card>

        <div class="text-center text-slate-500 font-medium">OR</div>

        <Card title="Option 2: Upload Your Own File">
          <BundleUploader 
            client:load
            onUpload={(bundle) => {
              window.dispatchEvent(new CustomEvent('bundleSelected', { 
                detail: { bundle, patientId } 
              }));
            }}
          />
        </Card>

        <div id="bundle-preview-container" class="hidden">
          <!-- Bundle preview will be rendered here dynamically -->
        </div>
      </div>

      <div class="mt-6">
        <a href="/patients" class="text-primary-600 hover:text-primary-700 text-sm font-medium">
          ← Back to patients
        </a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>

<script>
  import { patchBundleSubjectReference } from '@/lib/fhir-utils';
  import { submitBundle } from '@/lib/fhir-client';

  // Handle bundle selection
  window.addEventListener('bundleSelected', async (event: any) => {
    const { bundle, patientId, example } = event.detail;
    const container = document.getElementById('bundle-preview-container');
    
    if (!container) return;

    // Show preview container
    container.classList.remove('hidden');

    // Patch bundle if patientId is provided
    const patchedBundle = patientId 
      ? patchBundleSubjectReference(bundle, patientId)
      : bundle;

    // Render preview (simplified - in production use React component)
    container.innerHTML = `
      <div class="bg-white rounded-lg shadow-md border border-slate-200 p-6 space-y-4">
        <div class="flex justify-between items-center">
          <h3 class="text-lg font-semibold text-slate-900">Bundle Preview</h3>
          <button id="submit-bundle" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
            Submit Bundle
          </button>
        </div>
        <div class="bg-slate-50 rounded p-4">
          <pre class="text-xs overflow-auto max-h-64">${JSON.stringify(patchedBundle, null, 2)}</pre>
        </div>
        <div id="submit-status"></div>
      </div>
    `;

    // Add submit handler
    document.getElementById('submit-bundle')?.addEventListener('click', async () => {
      const statusDiv = document.getElementById('submit-status');
      if (!statusDiv) return;

      try {
        statusDiv.innerHTML = '<p class="text-primary-600">Submitting bundle...</p>';
        await submitBundle(patchedBundle);
        statusDiv.innerHTML = '<p class="text-success-600 font-medium">✓ Bundle submitted successfully!</p>';
        
        if (patientId) {
          setTimeout(() => {
            window.location.href = `/summary/${patientId}`;
          }, 1500);
        }
      } catch (error: any) {
        statusDiv.innerHTML = `<p class="text-error-600 font-medium">✗ Error: ${error.message}</p>`;
      }
    });
  });
</script>
