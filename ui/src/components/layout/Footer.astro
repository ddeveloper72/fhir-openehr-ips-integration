---
import { APP_VERSION } from '@/lib/constants';
---

<footer class="bg-white border-t border-slate-200 mt-auto">
  <div class="container-custom py-8">
    <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
      <div class="text-sm text-slate-600">
        <p>&copy; {new Date().getFullYear()} FHIR-openEHR Integration. Version {APP_VERSION}</p>
      </div>
      <div class="flex space-x-6 text-sm text-slate-600">
        <a href="https://hl7.org/fhir/uv/ips/" target="_blank" rel="noopener noreferrer" class="hover:text-primary-600">
          IPS Documentation
        </a>
        <a href="https://www.openehr.org/" target="_blank" rel="noopener noreferrer" class="hover:text-primary-600">
          openEHR
        </a>
        <a href="https://github.com/openFHIR" target="_blank" rel="noopener noreferrer" class="hover:text-primary-600">
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
